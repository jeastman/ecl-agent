$la-background: #101418;
$la-surface: #182028;
$la-panel: #202a34;
$la-status: #27313b;
$la-border: #3f4b57;
$la-focus: #67b7dc;
$la-accent: #8ccf7e;
$la-success: #5cb85c;
$la-warning: #f0c36a;
$la-danger: #d96c6c;
$la-text: #f1f6f8;
$la-muted: #b2bcc4;
$la-bg-base: #0c1015;
$la-bg-elevated: #1c2430;
$la-bg-overlay: #242e3a;
$la-bg-input: #1a2230;
$la-border-subtle: #2a3440;
$la-border-default: #3a4650;
$la-border-urgent: #d96c6c;
$la-text-title: #ffffff;
$la-text-secondary: #9aa8b8;
$la-text-muted-deep: #6b7a8a;

Screen {
    layout: vertical;
    background: $la-bg-base;
    color: $la-text;
}

.panel {
    border: round $la-border-subtle;
    background: $la-surface;
    padding: 1;
}

#status-bar {
    dock: top;
    height: 3;
    min-height: 3;
}

#identity-bar {
    height: 1;
    background: $la-bg-overlay;
    padding: 0 1;
    color: $la-text;
    content-align: left middle;
}

#context-bar {
    height: 1;
    background: $la-surface;
    padding: 0 1;
    color: $la-text-secondary;
    content-align: left middle;
    border-bottom: solid $la-border-subtle;
}

#dashboard-root,
#task-detail-root,
#approvals-screen-root,
#artifacts-screen-root,
#markdown-viewer-root,
#memory-screen-root,
#config-screen-root,
#diagnostics-screen-root {
    layout: vertical;
    height: 1fr;
    padding: 1;
}

#toast-rack {
    dock: bottom;
    align: right bottom;
    width: 48;
    height: auto;
    padding: 0;
    margin: 0 1 1 0;
    layer: overlay;
}

.toast-item {
    border: round $la-border-default;
    background: $la-bg-overlay;
    color: $la-text;
    padding: 0 1;
    margin-top: 1;
}

.toast-item.-info {
    border-left: heavy $la-focus;
}

.toast-item.-success {
    border-left: heavy $la-success;
}

.toast-item.-warning {
    border-left: heavy $la-warning;
}

.toast-item.-error {
    border-left: heavy $la-danger;
}

#dashboard-main {
    layout: horizontal;
    height: 1fr;
}

#dashboard-main.-narrow {
    layout: vertical;
}

#dashboard-main.-wide #dashboard-task-list {
    width: 22%;
}

#task-detail-main {
    layout: horizontal;
    height: 1fr;
}

#task-detail-main.-narrow {
    layout: vertical;
}

#approvals-screen-main {
    layout: horizontal;
    height: 1fr;
}

#artifacts-screen-main {
    layout: horizontal;
    height: 1fr;
}

#memory-screen-main {
    layout: horizontal;
    height: 1fr;
}

#config-screen-main {
    layout: horizontal;
    height: 1fr;
}

#diagnostics-screen-main {
    layout: horizontal;
    height: 1fr;
}

#dashboard-task-list {
    width: 25%;
    min-width: 26;
    border: round $la-border-default;
    margin-right: 1;
    padding: 0 1;
    background: $la-surface;
    tint: $la-surface 3%;
}

.task-list-row {
    height: 4;
    min-height: 4;
    padding: 0 1;
}

.task-list-row.-compact {
    height: 2;
    min-height: 2;
}

.task-list-row:even {
    background: $la-surface;
}

.task-list-row:odd {
    background: $la-background;
}

.task-list-row-content {
    width: 1fr;
}

#task-summary {
    width: 1fr;
    border: round $la-border-default;
    padding: 1;
    margin-right: 1;
    overflow-y: auto;
    background: $la-surface;
    tint: $la-surface 3%;
}

#task-summary-content {
    width: 1fr;
}

#dashboard-side-column {
    width: 35%;
    min-width: 30;
    height: 1fr;
}

#dashboard-side-column.-narrow {
    layout: horizontal;
    width: 1fr;
    min-width: 0;
    height: 12;
    margin-top: 1;
}

#dashboard-side-column.-narrow #approval-queue,
#dashboard-side-column.-narrow #recent-artifacts {
    width: 1fr;
    height: 1fr;
}

#dashboard-side-column.-narrow #approval-queue {
    margin-right: 1;
}

#dashboard-root.-narrow #dashboard-task-list,
#dashboard-root.-narrow #task-summary {
    width: 1fr;
    margin-right: 0;
}

#dashboard-root.-narrow #dashboard-task-list {
    height: 10;
    margin-bottom: 1;
}

#dashboard-root.-narrow #task-summary {
    height: 1fr;
}

#dashboard-root.-wide #dashboard-side-column {
    width: 32%;
}

#dashboard-main.-side-collapsed #task-summary {
    margin-right: 0;
}

#approval-queue,
#recent-artifacts,
#approvals-screen-queue,
#approvals-screen-detail,
#artifacts-screen-table,
#artifacts-screen-preview,
#memory-screen-groups,
#memory-screen-group-summary,
#memory-screen-entries,
#memory-screen-detail,
#config-screen-sections,
#config-screen-detail,
#markdown-viewer-body,
#task-detail-header,
#task-detail-timeline,
#task-detail-plan,
#task-detail-todos,
#task-detail-subagents,
#task-detail-artifacts,
#task-detail-remote-mcp,
#task-detail-notifications,
#task-detail-input,
#diagnostics-screen-list,
#diagnostics-screen-detail,
#command-palette-panel,
#help-screen-panel,
#create-task-panel,
#task-timeline-prompt-panel,
#confirm-dialog-panel,
#runtime-user-panel,
#remote-mcp-authorize-panel,
#remote-mcp-complete-panel {
    border: round $la-border-subtle;
    background: $la-bg-base;
    padding: 1;
}

#task-detail-timeline,
#task-detail-logs,
#task-detail-header {
    border: round $la-border-default;
    background: $la-surface;
    tint: $la-surface 3%;
}

#approval-queue,
#recent-artifacts,
#task-detail-artifacts,
#task-detail-notifications,
#task-detail-remote-mcp {
    padding: 0 1;
}

#confirm-dialog-panel,
#runtime-user-panel,
#remote-mcp-authorize-panel,
#remote-mcp-complete-panel,
#help-screen-panel {
    width: 64;
    max-width: 80%;
    height: auto;
    border: heavy $la-focus;
    background: $la-bg-overlay;
}

#help-screen-panel {
    height: 85%;
    max-height: 85%;
    padding: 1 1 0 1;
}

#help-screen-title {
    text-style: bold;
    color: $la-text-title;
    margin-bottom: 0;
}

#help-screen-subtitle {
    color: $la-text-secondary;
    margin-bottom: 1;
}

#help-screen-scroll {
    height: 1fr;
    border: round $la-border-subtle;
    background: $la-bg-base;
    padding: 0 1;
    overflow-y: auto;
}

#help-screen-body {
    width: 1fr;
    padding: 0 0 1 0;
}

#help-screen-footer {
    color: $la-text-muted-deep;
    margin-top: 1;
    padding: 0 0 1 0;
}

#confirm-dialog-panel.-danger {
    border: heavy $la-danger;
}

#confirm-dialog-title {
    text-style: bold;
    color: $la-text-title;
    margin-bottom: 1;
}

#confirm-dialog-body {
    color: $la-text-secondary;
    margin-bottom: 1;
}

#confirm-dialog-actions {
    layout: horizontal;
    height: auto;
}

#remote-mcp-authorize-url {
    border: round $la-border-subtle;
    background: $la-bg-input;
    color: $la-text;
    padding: 1;
    margin: 1 0;
}

.confirm-dialog-button {
    margin-right: 1;
}

.confirm-dialog-button.-danger {
    background: $la-danger;
    color: $la-text-title;
}

#task-detail-header,
#task-detail-input {
    height: auto;
    padding: 0 1;
}

#task-detail-header {
    max-height: 4;
}

#task-detail-footer {
    padding: 0 1;
}

#task-detail-timeline {
    width: 60%;
    height: 1fr;
    margin-right: 1;
    overflow-y: auto;
}

#task-detail-logs {
    width: 60%;
    height: 1fr;
    margin-right: 1;
    overflow-y: auto;
}

#task-detail-side {
    width: 40%;
    height: 1fr;
    overflow-y: auto;
}

#task-detail-main.-narrow #task-detail-timeline,
#task-detail-main.-narrow #task-detail-logs,
#task-detail-main.-narrow #task-detail-side {
    width: 1fr;
    margin-right: 0;
}

#task-detail-main.-narrow #task-detail-timeline,
#task-detail-main.-narrow #task-detail-logs {
    height: 1fr;
    margin-bottom: 1;
}

#task-detail-main.-narrow #task-detail-side {
    height: 16;
}

#task-detail-main.-wide #task-detail-timeline,
#task-detail-main.-wide #task-detail-logs {
    width: 65%;
}

#task-detail-main.-wide #task-detail-side {
    width: 35%;
}

#task-detail-main.-split-50-50 #task-detail-timeline,
#task-detail-main.-split-50-50 #task-detail-logs {
    width: 50%;
}

#task-detail-main.-split-50-50 #task-detail-side {
    width: 50%;
}

#task-detail-main.-split-60-40 #task-detail-timeline,
#task-detail-main.-split-60-40 #task-detail-logs {
    width: 60%;
}

#task-detail-main.-split-60-40 #task-detail-side {
    width: 40%;
}

#task-detail-main.-split-70-30 #task-detail-timeline,
#task-detail-main.-split-70-30 #task-detail-logs {
    width: 70%;
}

#task-detail-main.-split-70-30 #task-detail-side {
    width: 30%;
}

#task-detail-plan,
#task-detail-todos,
#task-detail-subagents,
#task-detail-artifacts,
#task-detail-remote-mcp,
#task-detail-notifications {
    height: auto;
    min-height: 7;
    margin-bottom: 1;
    overflow-y: auto;
}

#task-detail-plan.-empty-panel,
#task-detail-todos.-empty-panel,
#task-detail-subagents.-empty-panel,
#task-detail-artifacts.-empty-panel,
#task-detail-remote-mcp.-empty-panel,
#task-detail-notifications.-empty-panel {
    min-height: 2;
}

#task-detail-notifications {
    min-height: 4;
}

#task-detail-command-status {
    color: $la-text-secondary;
    height: auto;
    margin-bottom: 0;
}

#task-detail-command-suggestion {
    height: auto;
    margin-top: 0;
    margin-bottom: 0;
}

#task-detail-notifications.-urgent-pane {
    border: heavy $la-border-urgent;
}

#task-detail-command-input {
    border: round $la-border-subtle;
    background: $la-bg-input;
    color: $la-text;
}

#task-detail-command-input:focus {
    border: heavy $la-focus;
}

#task-detail-command-input:disabled {
    background: $la-bg-base;
    color: $la-text-muted-deep;
}

#recent-artifacts {
    margin-top: 1;
    height: 1fr;
    overflow-y: auto;
}

#approvals-screen-queue {
    width: 48%;
    margin-right: 1;
}

#approvals-screen-detail {
    width: 52%;
}

#artifacts-screen-table {
    width: 48%;
    margin-right: 1;
}

#artifacts-screen-preview {
    width: 52%;
}

#memory-screen-groups {
    width: 34%;
    margin-right: 1;
}

#memory-screen-side {
    width: 66%;
    height: 1fr;
}

#memory-screen-group-summary {
    height: auto;
    margin-bottom: 1;
}

#memory-screen-entries {
    height: 18;
    margin-bottom: 1;
}

#memory-screen-detail {
    height: 1fr;
}

#config-screen-sections {
    width: 34%;
    margin-right: 1;
}

#config-screen-sections ListItem {
    height: auto;
    min-height: 4;
    padding: 0 1;
}

#config-screen-sections ListItem.-selected {
    background: $la-bg-elevated;
    tint: $la-focus 5%;
}

.config-section-row-content {
    width: 1fr;
}

#config-screen-detail-column {
    width: 66%;
    height: 1fr;
}

#config-screen-profiles {
    height: auto;
    margin-bottom: 1;
    border: round $la-border-subtle;
    background: $la-bg-elevated;
    color: $la-text-secondary;
    padding: 0 1;
}

#config-screen-detail {
    height: 1fr;
}

#diagnostics-screen-list {
    width: 42%;
    margin-right: 1;
}

#diagnostics-screen-detail {
    width: 58%;
}

#markdown-viewer-body {
    height: 1fr;
}

#markdown-viewer-search-row {
    height: auto;
    margin-bottom: 1;
    align: left middle;
}

#markdown-viewer-search-label {
    width: 8;
    color: $la-muted;
}

#markdown-viewer-search-input {
    width: 1fr;
}

#dashboard-footer,
#task-detail-footer,
#approvals-screen-footer,
#artifacts-screen-footer,
#memory-screen-footer,
#config-screen-footer,
#diagnostics-screen-footer {
    height: 2;
    min-height: 2;
    border: none;
    background: $la-bg-base;
    padding: 0 2;
    margin-top: 1;
    color: $la-muted;
    content-align: left middle;
}

#markdown-viewer-footer {
    height: auto;
    min-height: 3;
    border: solid $la-border;
    background: $la-surface;
    padding: 0 2;
    margin-top: 1;
    color: $la-muted;
    content-align: left middle;
}

.-focused-pane {
    border: heavy $la-focus;
    background: $la-bg-elevated;
    tint: $la-focus 5%;
}

.-hidden {
    display: none;
}

CommandPaletteScreen,
CreateTaskScreen,
TaskTimelinePromptScreen {
    align: center middle;
    background: rgba(10, 14, 18, 0.88);
}

#command-palette-panel,
#create-task-panel,
#task-timeline-prompt-panel {
    width: 72;
    max-width: 90%;
    height: auto;
    border: heavy $la-focus;
    background: $la-bg-overlay;
}

#command-palette-input,
#task-timeline-prompt-input,
#task-detail-command-input {
    margin-bottom: 1;
}

#create-task-input {
    height: 8;
    min-height: 6;
    margin-bottom: 1;
    background: $la-bg-input;
    border: round $la-border-subtle;
    padding: 0 1;
}

#create-task-input .text-area--gutter,
#create-task-input .text-area--cursor-gutter,
#create-task-input .text-area--cursor-line {
    background: $la-surface;
}

#create-task-input .text-area--gutter,
#create-task-input .text-area--cursor-gutter {
    color: $la-surface;
}

#create-task-input:focus {
    border: heavy $la-focus;
}

#command-palette-results,
#create-task-status,
#task-timeline-prompt-status,
#task-detail-command-status {
    color: $la-muted;
}

#command-palette-title,
#create-task-title {
    text-style: bold;
    color: $la-text-title;
    margin-bottom: 1;
}

#create-task-subtitle {
    color: $la-text-secondary;
    margin-bottom: 1;
}

#command-palette-results {
    border-top: solid $la-border-subtle;
    padding-top: 1;
}

#task-detail-input {
    height: auto;
    min-height: 4;
    padding-top: 0;
    padding-bottom: 0;
}

.panel {
    border: round $la-border;
    background: $la-surface;
    padding: 1;
}

.-urgent-pane {
    border: heavy $la-border-urgent;
}
