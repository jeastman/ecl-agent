$la-background: #101418;
$la-surface: #182028;
$la-panel: #202a34;
$la-status: #27313b;
$la-border: #3f4b57;
$la-focus: #67b7dc;
$la-accent: #8ccf7e;
$la-success: #5cb85c;
$la-warning: #f0c36a;
$la-danger: #d96c6c;
$la-text: #f1f6f8;
$la-muted: #b2bcc4;
$la-bg-base: #0c1015;
$la-bg-elevated: #1c2430;
$la-bg-overlay: #242e3a;
$la-bg-input: #1a2230;
$la-border-subtle: #2a3440;
$la-border-default: #3a4650;
$la-border-urgent: #d96c6c;
$la-text-title: #ffffff;
$la-text-secondary: #9aa8b8;
$la-text-muted-deep: #6b7a8a;

Screen {
    layout: vertical;
    background: $la-background;
    color: $la-text;
}

#status-bar {
    dock: top;
    height: 2;
    min-height: 2;
    background: $la-status;
    color: $la-text;
    padding: 0 1;
    content-align: left middle;
    border-bottom: solid $la-border;
}

#dashboard-root,
#task-detail-root,
#approvals-screen-root,
#artifacts-screen-root,
#markdown-viewer-root,
#memory-screen-root,
#config-screen-root,
#diagnostics-screen-root {
    layout: vertical;
    height: 1fr;
    padding: 1;
}

#dashboard-main {
    layout: horizontal;
    height: 1fr;
}

#task-detail-main {
    layout: horizontal;
    height: 1fr;
}

#approvals-screen-main {
    layout: horizontal;
    height: 1fr;
}

#artifacts-screen-main {
    layout: horizontal;
    height: 1fr;
}

#memory-screen-main {
    layout: horizontal;
    height: 1fr;
}

#config-screen-main {
    layout: horizontal;
    height: 1fr;
}

#diagnostics-screen-main {
    layout: horizontal;
    height: 1fr;
}

#dashboard-task-list {
    width: 30%;
    min-width: 28;
    border: solid $la-border;
    margin-right: 1;
    padding: 0;
}

.task-list-row {
    height: 4;
    min-height: 4;
    padding: 0 1;
    border-bottom: solid $la-border;
}

.task-list-row-content {
    width: 1fr;
}

#task-summary {
    width: 1fr;
    border: solid $la-border;
    padding: 1;
    margin-right: 1;
    overflow-y: auto;
}

#task-summary-content {
    width: 1fr;
}

#dashboard-side-column {
    width: 34%;
    min-width: 30;
    height: 1fr;
}

#approval-queue,
#recent-artifacts,
#approvals-screen-queue,
#approvals-screen-detail,
#artifacts-screen-table,
#artifacts-screen-preview,
#memory-screen-groups,
#memory-screen-group-summary,
#memory-screen-entries,
#memory-screen-detail,
#config-screen-sections,
#config-screen-detail,
#markdown-viewer-body,
#task-detail-header,
#task-detail-timeline,
#task-detail-plan,
#task-detail-subagents,
#task-detail-artifacts,
#task-detail-notifications,
#task-detail-input,
#diagnostics-screen-list,
#diagnostics-screen-detail,
#command-palette-panel,
#create-task-panel,
#task-timeline-prompt-panel {
    border: solid $la-border;
    background: $la-surface;
    padding: 1;
}

#task-detail-header,
#task-detail-input {
    height: auto;
    padding: 0 1;
}

#task-detail-header {
    max-height: 12;
}

#task-detail-footer {
    padding: 0 1;
}

#task-detail-timeline {
    width: 58%;
    height: 1fr;
    margin-right: 1;
    overflow-y: auto;
}

#task-detail-logs {
    width: 58%;
    height: 1fr;
    margin-right: 1;
    overflow-y: auto;
}

#task-detail-side {
    width: 42%;
    height: 1fr;
    overflow-y: auto;
}

#task-detail-plan,
#task-detail-subagents,
#task-detail-artifacts,
#task-detail-notifications {
    height: auto;
    min-height: 7;
    margin-bottom: 1;
    overflow-y: auto;
}

#recent-artifacts {
    margin-top: 1;
    height: 1fr;
}

#approvals-screen-queue {
    width: 48%;
    margin-right: 1;
}

#approvals-screen-detail {
    width: 52%;
}

#artifacts-screen-table {
    width: 48%;
    margin-right: 1;
}

#artifacts-screen-preview {
    width: 52%;
}

#memory-screen-groups {
    width: 34%;
    margin-right: 1;
}

#memory-screen-side {
    width: 66%;
    height: 1fr;
}

#memory-screen-group-summary {
    height: auto;
    margin-bottom: 1;
}

#memory-screen-entries {
    height: 18;
    margin-bottom: 1;
}

#memory-screen-detail {
    height: 1fr;
}

#config-screen-sections {
    width: 34%;
    margin-right: 1;
}

#config-screen-detail {
    width: 66%;
    height: 1fr;
}

#diagnostics-screen-list {
    width: 42%;
    margin-right: 1;
}

#diagnostics-screen-detail {
    width: 58%;
}

#markdown-viewer-body {
    height: 1fr;
}

#markdown-viewer-search-row {
    height: auto;
    margin-bottom: 1;
    align: left middle;
}

#markdown-viewer-search-label {
    width: 8;
    color: $la-muted;
}

#markdown-viewer-search-input {
    width: 1fr;
}

#dashboard-footer,
#task-detail-footer,
#approvals-screen-footer,
#artifacts-screen-footer,
#markdown-viewer-footer,
#memory-screen-footer,
#config-screen-footer,
#diagnostics-screen-footer {
    height: auto;
    min-height: 3;
    border: solid $la-border;
    background: $la-surface;
    padding: 0 2;
    margin-top: 1;
    color: $la-muted;
    content-align: left middle;
}

.-focused-pane {
    border: heavy $la-focus;
    background: #1f3140;
    tint: $la-focus 5%;
}

.-hidden {
    display: none;
}

CommandPaletteScreen,
CreateTaskScreen,
TaskTimelinePromptScreen {
    align: center middle;
    background: rgba(10, 14, 18, 0.88);
}

#command-palette-panel,
#create-task-panel,
#task-timeline-prompt-panel {
    width: 72;
    max-width: 90%;
    height: auto;
}

#command-palette-input,
#task-timeline-prompt-input,
#task-detail-command-input {
    margin-bottom: 1;
}

#create-task-input {
    height: 8;
    min-height: 6;
    margin-bottom: 1;
    background: $la-surface;
    border: none;
    padding: 0;
}

#create-task-input .text-area--gutter,
#create-task-input .text-area--cursor-gutter,
#create-task-input .text-area--cursor-line {
    background: $la-surface;
}

#create-task-input .text-area--gutter,
#create-task-input .text-area--cursor-gutter {
    color: $la-surface;
}

#create-task-input:focus {
    border: none;
}

#command-palette-results,
#create-task-status,
#task-timeline-prompt-status,
#task-detail-command-status {
    color: $la-muted;
}

#task-detail-input {
    height: auto;
}

.panel {
    border: round $la-border;
    background: $la-surface;
    padding: 1;
}

.-urgent-pane {
    border: heavy $la-border-urgent;
}
