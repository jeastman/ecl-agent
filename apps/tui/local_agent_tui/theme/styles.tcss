$la-background: #101418;
$la-surface: #182028;
$la-panel: #202a34;
$la-status: #27313b;
$la-border: #3f4b57;
$la-focus: #67b7dc;
$la-accent: #8ccf7e;
$la-success: #5cb85c;
$la-warning: #f0c36a;
$la-danger: #d96c6c;
$la-text: #f1f6f8;
$la-muted: #b2bcc4;

Screen {
    layout: vertical;
    background: $la-background;
    color: $la-text;
}

#status-bar {
    dock: top;
    height: 1;
    background: $la-status;
    color: $la-text;
    padding: 0 1;
}

#dashboard-root,
#task-detail-root,
#approvals-screen-root,
#artifacts-screen-root,
#markdown-viewer-root,
#memory-screen-root,
#config-screen-root,
#diagnostics-screen-root {
    layout: vertical;
    height: 1fr;
    padding: 1;
}

#dashboard-main {
    layout: horizontal;
    height: 1fr;
}

#task-detail-main {
    layout: horizontal;
    height: 1fr;
}

#approvals-screen-main {
    layout: horizontal;
    height: 1fr;
}

#artifacts-screen-main {
    layout: horizontal;
    height: 1fr;
}

#memory-screen-main {
    layout: horizontal;
    height: 1fr;
}

#config-screen-main {
    layout: horizontal;
    height: 1fr;
}

#diagnostics-screen-main {
    layout: horizontal;
    height: 1fr;
}

#dashboard-task-list {
    width: 30%;
    min-width: 28;
    border: solid $la-border;
    margin-right: 1;
}

#task-summary {
    width: 1fr;
    border: solid $la-border;
    padding: 1;
    margin-right: 1;
}

#dashboard-side-column {
    width: 34%;
    min-width: 30;
    height: 1fr;
}

#approval-queue,
#recent-artifacts,
#approvals-screen-queue,
#approvals-screen-detail,
#artifacts-screen-table,
#artifacts-screen-preview,
#memory-screen-groups,
#memory-screen-group-summary,
#memory-screen-entries,
#memory-screen-detail,
#config-screen-sections,
#config-screen-detail,
#markdown-viewer-body,
#task-detail-header,
#task-detail-timeline,
#task-detail-plan,
#task-detail-subagents,
#task-detail-artifacts,
#task-detail-notifications,
#task-detail-input,
#diagnostics-screen-list,
#diagnostics-screen-detail,
#command-palette-panel,
#create-task-panel {
    border: solid $la-border;
    background: $la-surface;
    padding: 1;
}

#task-detail-header,
#task-detail-input {
    height: auto;
}

#task-detail-timeline {
    width: 58%;
    margin-right: 1;
}

#task-detail-side {
    width: 42%;
    height: 1fr;
}

#task-detail-plan,
#task-detail-subagents,
#task-detail-artifacts,
#task-detail-notifications {
    height: 1fr;
    margin-bottom: 1;
}

#recent-artifacts {
    margin-top: 1;
    height: 1fr;
}

#approvals-screen-queue {
    width: 48%;
    margin-right: 1;
}

#approvals-screen-detail {
    width: 52%;
}

#artifacts-screen-table {
    width: 48%;
    margin-right: 1;
}

#artifacts-screen-preview {
    width: 52%;
}

#memory-screen-groups {
    width: 34%;
    margin-right: 1;
}

#memory-screen-side {
    width: 66%;
    height: 1fr;
}

#memory-screen-group-summary {
    height: auto;
    margin-bottom: 1;
}

#memory-screen-entries {
    height: 18;
    margin-bottom: 1;
}

#memory-screen-detail {
    height: 1fr;
}

#config-screen-sections {
    width: 34%;
    margin-right: 1;
}

#config-screen-detail {
    width: 66%;
    height: 1fr;
}

#diagnostics-screen-list {
    width: 42%;
    margin-right: 1;
}

#diagnostics-screen-detail {
    width: 58%;
}

#markdown-viewer-body {
    height: 1fr;
}

#markdown-viewer-search-row {
    height: auto;
    margin-bottom: 1;
    align: left middle;
}

#markdown-viewer-search-label {
    width: 8;
    color: $la-muted;
}

#markdown-viewer-search-input {
    width: 1fr;
}

#dashboard-footer,
#task-detail-footer,
#approvals-screen-footer,
#artifacts-screen-footer,
#markdown-viewer-footer,
#memory-screen-footer,
#config-screen-footer,
#diagnostics-screen-footer {
    height: 3;
    border: solid $la-border;
    background: $la-surface;
    padding: 1 2;
    margin-top: 1;
    color: $la-muted;
}

.-focused-pane {
    border: heavy $la-focus;
}

.-hidden {
    display: none;
}

CommandPaletteScreen,
CreateTaskScreen {
    align: center middle;
    background: rgba(10, 14, 18, 0.82);
}

#command-palette-panel,
#create-task-panel {
    width: 72;
    max-width: 90%;
    height: auto;
}

#command-palette-input,
#create-task-input {
    margin-bottom: 1;
}

#command-palette-results,
#create-task-status {
    color: $la-muted;
}
