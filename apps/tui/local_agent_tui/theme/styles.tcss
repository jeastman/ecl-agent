Screen {
    layout: vertical;
    background: rgb(16, 20, 24);
    color: rgb(241, 246, 248);
}

#status-bar {
    dock: top;
    height: 1;
    background: rgb(34, 39, 46);
    color: rgb(241, 246, 248);
    padding: 0 1;
}

#dashboard-root,
#task-detail-root,
#approvals-screen-root {
    layout: vertical;
    height: 1fr;
    padding: 1;
}

#dashboard-main {
    layout: horizontal;
    height: 1fr;
}

#dashboard-task-list {
    width: 30%;
    min-width: 28;
    border: solid rgb(55, 65, 76);
    margin-right: 1;
}

#task-summary {
    width: 1fr;
    border: solid rgb(55, 65, 76);
    padding: 1;
    margin-right: 1;
}

#dashboard-side-column {
    width: 34%;
    min-width: 30;
    height: 1fr;
}

#approval-queue,
#recent-artifacts,
#task-detail-body,
#approvals-screen-queue {
    border: solid rgb(55, 65, 76);
    padding: 1;
}

#recent-artifacts {
    margin-top: 1;
    height: 1fr;
}

#dashboard-footer,
#task-detail-footer,
#approvals-screen-footer {
    height: 3;
    border: solid rgb(55, 65, 76);
    padding: 1 2;
    margin-top: 1;
    color: rgb(190, 201, 209);
}

.-focused-pane {
    border: heavy rgb(116, 185, 255);
}
